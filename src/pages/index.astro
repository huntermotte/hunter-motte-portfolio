---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const recentPosts = (
  await getCollection("blog", ({ data }) => !data.draft)
)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<Layout>
  <section class="mx-auto max-w-3xl px-6 sm:px-8 pt-24 sm:pt-32">
    <p class="font-display italic text-base text-pine dark:text-pine-bright mb-6">
      Currently —
    </p>

    <h1
      class="font-display text-5xl sm:text-6xl md:text-7xl leading-[1.05] tracking-tight"
    >
      Engineering leader,
      <span class="text-pine dark:text-pine-bright italic">building</span>
      teams that ship.
    </h1>

    <p
      class="mt-8 text-lg sm:text-xl leading-relaxed max-w-2xl text-coal/80 dark:text-bone-dim/80"
    >
      Former software engineer, now Engineering Manager — drawn to the work
      that sits between systems and people. Looking for the next room where
      that work matters.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-3">
      <a
        href="/about"
        class="font-display italic text-lg text-pine dark:text-pine-bright hover:text-rust dark:hover:text-rust-bright transition-colors"
      >
        Read more <span aria-hidden="true">→</span>
      </a>
      <a
        href="/blog"
        class="font-display italic text-lg hover:text-rust dark:hover:text-rust-bright transition-colors"
      >
        Blog <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-6 sm:px-8 mt-32">
    <div class="border-t hairline pt-10">
      <p class="font-display italic text-base text-pine dark:text-pine-bright mb-6">
        Recent writing —
      </p>

      {
        recentPosts.length === 0 ? (
          <p class="text-coal/60 dark:text-bone-dim/60">
            First post coming soon.
          </p>
        ) : (
          <ul class="divide-y hairline">
            {recentPosts.map((post) => (
              <li>
                <a href={`/blog/${post.id}`} class="block py-5 group">
                  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
                    <h3 class="font-display text-xl group-hover:text-rust dark:group-hover:text-rust-bright transition-colors">
                      {post.data.title}
                    </h3>
                    <time
                      datetime={post.data.pubDate.toISOString()}
                      class="font-mono text-xs text-coal/60 dark:text-bone-dim/60 shrink-0"
                    >
                      {formatDate(post.data.pubDate)}
                    </time>
                  </div>
                  <p class="mt-1 text-sm text-coal/70 dark:text-bone-dim/70">
                    {post.data.description}
                  </p>
                </a>
              </li>
            ))}
          </ul>
        )
      }

      <a
        href="/blog"
        class="font-display italic text-base text-pine dark:text-pine-bright hover:text-rust dark:hover:text-rust-bright transition-colors inline-block mt-6"
      >
        Read the blog <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Layout>
