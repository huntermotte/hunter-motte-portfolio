---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Off the map" description="That page doesn't exist.">
  <section class="mx-auto max-w-3xl px-6 sm:px-8 pt-20 sm:pt-28 text-center">
    <p class="font-mono text-xs text-coal/60 dark:text-bone-dim/60 mb-6">
      404
    </p>
    <h1 class="font-display text-5xl sm:text-7xl leading-[1.05] tracking-tight">
      Not here.
    </h1>
    <p class="mt-6 text-lg text-coal/70 dark:text-bone-dim/70">
      That page doesn't exist.
    </p>
    <div class="mt-10 flex justify-center gap-8">
      <a
        href="/"
        class="font-display italic text-lg text-pine dark:text-pine-bright hover:text-rust dark:hover:text-rust-bright transition-colors"
      >
        Back home <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Layout>
