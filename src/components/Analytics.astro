---
// Google Analytics 4 (gtag.js). Only loads in production builds so local
// dev traffic doesn't skew the numbers.
const GA_ID = "G-9FJ8X2YDWQ";
const enabled = import.meta.env.PROD;
---

{
  enabled && (
    <>
      <script
        is:inline
        async
        src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
      />
      <script is:inline define:vars={{ GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag("js", new Date());
        gtag("config", GA_ID);
      </script>
    </>
  )
}
