---
import ThemeToggle from "./ThemeToggle.astro";

const links = [
  { href: "/about", label: "About" },
  { href: "/work", label: "Built" },
  { href: "/blog", label: "Blog" },
  { href: "/now", label: "Now" },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="border-b hairline">
  <nav
    class="mx-auto max-w-5xl px-6 sm:px-8 h-16 flex items-center justify-between"
  >
    <a
      href="/"
      class="font-display text-xl tracking-tight hover:text-rust dark:hover:text-rust-bright transition-colors"
      aria-label="Hunter Motte — home"
    >
      Hunter Motte
    </a>

    <div class="flex items-center gap-6 sm:gap-8">
      <ul class="hidden sm:flex items-center gap-6 sm:gap-7">
        {
          links.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  "text-sm text-coal/70 dark:text-bone-dim/70 hover:text-pine dark:hover:text-pine-bright transition-colors",
                  isActive(href) &&
                    "font-medium text-pine dark:text-pine-bright",
                ]}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
      <ThemeToggle />
    </div>
  </nav>
</header>
